{
  "name": "ai-survival-index",
  "private": true,
  "version": "0.1.0",
  "description": "AI 時代生存指數 Alpha product workspace",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @ai-survival/shared build && pnpm --filter @ai-survival/api build && pnpm --filter @ai-survival/web build",
    "check": "pnpm --filter @ai-survival/shared build && pnpm -r check",
    "typecheck": "pnpm --filter @ai-survival/shared build && pnpm -r typecheck",
    "build:alpha-pages": "node scripts/build-alpha-pages.cjs",
    "dev:web": "pnpm --filter @ai-survival/web dev",
    "dev:api": "pnpm --filter @ai-survival/api dev",
    "supabase": "supabase",
    "supabase:start": "supabase start --exclude storage-api,logflare,vector,imgproxy,edge-runtime --ignore-health-check",
    "supabase:start:full": "supabase start",
    "supabase:status": "supabase status",
    "supabase:stop": "supabase stop"
  },
  "devDependencies": {
    "supabase": "^2.107.0",
    "typescript": "^5.5.4"
  }
}
